package "Core Shared Library (Dependency-Free)" #FFFFFF {

    package "Domain Entities & Invariants" {
        class Message {
            +Message(Message &&) = default : void
            +Message(const Message &) = deleted : void
            +operator=(Message &&) = default : Message &
            +operator=(const Message &) = deleted : Message &
            {static} +Create<MessageValidatorFor TMessageValidator>(MessageParams params, const TMessageValidator & validator) : Message
            +CreatedAt() const : std::chrono::system_clock::time_point
            +GetChatId() const : const ChatId &
            +GetCiphertext() const : std::string_view
            +GetId() const : const MessageId &
            +GetSenderId() const : const UserId &
            +GetType() const : const MessageTypeVariant &
            +GetTypeStr() const : std::string
            {static} +Reconstitute(MessageParams params) : Message
        }

        class User {
            +User(User &&) = default : void
            +User(const User &) = deleted : void
            +operator=(User &&) = default : User &
            +operator=(const User &) = deleted : User &
            +CanPerform(UserAction action) const : bool
            {static} +Create<UserValidatorFor TUserValidator>(UserParams params, const TUserValidator & validator) : User
            +CreatedAt() const : std::chrono::system_clock::time_point
            +GetId() const : const UserId &
            +GetLogin() const : const std::string &
            +GetPasswordHash() const : const std::string &
            +GetPublicKey() const : const std::string &
            +GetRole() const : const UserRoleVariant &
            +GetRoleStr() const : std::string_view
            +GetTag() const : const tags::UserTag &
            {static} +Reconstitute(UserParams params) : User
            +SetLogin(std::string login) : void
            +SetPasswordHash(std::string hash) : void
            +SetRole(UserRoleVariant role) : void
        }

        class Chat {
            +AddParticipant(UserId userId) : void
            {static} +Create<ChatValidatorFor TChatValidator>(ChatParams params, const TChatValidator & validator) : Chat
            +CreatedAt() const : std::chrono::system_clock::time_point
            +GetId() const : const ChatId &
            +GetLastMessage() const : const std::optional<Message> &
            +GetParticipantIds() const : const std::vector<UserId> &
            +GetType() const : const ChatTypeVariant &
            {static} +Reconstitute(ChatParams params) : Chat
            +RemoveParticipant(const UserId & userId) : void
            +SetLastMessage(Message message) : void
        }

        class Session {
            +Session(Session &&) = default : void
            +Session(const Session &) = deleted : void
            +operator=(Session &&) = default : Session &
            +operator=(const Session &) = deleted : Session &
            {static} +Create<SessionValidatorFor TSessionValidator>(SessionParams params, const TSessionValidator & validator) : Session
            +CreatedAt() const : std::chrono::system_clock::time_point
            +ExpiresAt() const : std::chrono::system_clock::time_point
            +GetId() const : const SessionId &
            +GetToken() const : const std::string &
            +GetUserId() const : const UserId &
            +IsExpired() const : bool
            {static} +Reconstitute(SessionParams params) : Session
            +Refresh(std::chrono::system_clock::duration duration) : void
        }
    }

package "Strongly Typed Identifiers" {
        together {
            class "BaseId<MessageId>" as BaseId_MessageId {
                {static} +Generate() : MessageId
                {static} +Parse(const std::string& id) : MessageId
                {static} +Reconstitute(std::string id) : MessageId
                +ToString() const : const std::string&
                +IsValid() const : bool
                +operator==(const BaseId&) const : bool
            }
            class MessageId
            BaseId_MessageId <|-- MessageId
            
            class "BaseId<ChatId>" as BaseId_ChatId {
                {static} +Generate() : ChatId
                {static} +Parse(const std::string& id) : ChatId
                {static} +Reconstitute(std::string id) : ChatId
                +ToString() const : const std::string&
                +IsValid() const : bool
                +operator==(const BaseId&) const : bool
            }
            class ChatId
            BaseId_ChatId <|-- ChatId
        }

        together {
            class "BaseId<UserId>" as BaseId_UserId {
                {static} +Generate() : UserId
                {static} +Parse(const std::string& id) : UserId
                {static} +Reconstitute(std::string id) : UserId
                +ToString() const : const std::string&
                +IsValid() const : bool
                +operator==(const BaseId&) const : bool
            }
            class UserId
            BaseId_UserId <|-- UserId

            class "BaseId<SessionId>" as BaseId_SessionId {
                {static} +Generate() : SessionId
                {static} +Parse(const std::string& id) : SessionId
                {static} +Reconstitute(std::string id) : SessionId
                +ToString() const : const std::string&
                +IsValid() const : bool
                +operator==(const BaseId&) const : bool
            }
            class SessionId
            BaseId_SessionId <|-- SessionId
        }
    }

    package "Metaprogramming & Infrastructure" {
            class "DomainClassTypeVariantFactory<std::variant<TTypes...>>" as VariantFactory {
                {static} +Create(std::string_view typeStr, TArgs&&... args) : std::variant<TTypes...>
            }

            class "MessageType<T>" as MessageType_T <<concept>> {
                (T payload)
                --
                {T::TypeString()} -> std::convertible_to<std::string_view>
            }
            
            class SystemMessageType {
                {static} +GetMaxLength() constexpr : std::size_t
                {static} +TypeString() constexpr : std::string_view
            }
            class TextMessageType {
                {static} +GetMaxLength() constexpr : std::size_t
                {static} +TypeString() constexpr : std::string_view
            }
            class DirectChatType {
                {static} +IsValid() constexpr noexcept : bool
                {static} +TypeString() constexpr noexcept : std::string_view
            }
            class RegularUserRole {
                {static} +CanPerform(UserAction action) : bool
                {static} +TypeString() constexpr : std::string_view
            }
            
            enum UserAction {
                kSendMessage
                kDeleteAccount
                kModifyLogin
                kModifyPassword
                kModifyTag
                kDeleteOwnMessage
                kDeleteAnyMessage
                kBanUser
                kManageRoles
            }
            
            interface "IValidator<T>" as IValidator_T {
                +~IValidator() = default
                {abstract} +Validate(const T& params) const : ValidationResult
            }
            
            class MessageValidator {
                {static} +GetCiphertextRule() constexpr : NotEmpty_t
                {static} +GetCreatedAtRule() constexpr : TimePointMustBeSet_t
                {static} +GetEncryptedKeysRule() constexpr : NotEmpty_t
                +Validate(const MessageParams & params) constexpr const : validation::ValidationResult<kMaxErrors>
            }
            class UserValidator {
                {static} +GetCreatedAtRule() constexpr : TimePointMustBeSet_t
                {static} +GetLoginRule() constexpr : validation::rules::AndRule<AndRule<NotEmpty_t,MinLength_t<3>>,MaxLength_t<32>>
                {static} +GetPasswordHashRule() constexpr : NotEmpty_t
                {static} +GetPublicKeyRule() constexpr : NotEmpty_t
                +Validate(const UserParams & params) constexpr const : validation::ValidationResult<kMaxErrors>
            }
            class ChatValidator {
                {static} +GetCreatedAtRule() constexpr : TimePointMustBeSet_t
                +Validate(const ChatParams & params) constexpr const : validation::ValidationResult<kMaxErrors>
            }
            class SessionValidator {
                {static} +GetCreatedAtRule(std::chrono::system_clock::time_point other) constexpr : validation::rules::AndRule<TimePointMustBeSet_t,IsLessThanInclusive_t<time_point<system_clock,duration<long long,ratio<1,10000000>>>>>
                {static} +GetExpiresAtRule() constexpr : TimePointMustBeSet_t
                {static} +GetTokenRule() constexpr : validation::rules::AndRule<NotEmpty_t,MinLength_t<32>>
                +Validate(const SessionParams & params) constexpr const : validation::ValidationResult<kMaxErrors>
                {static} +kMinTokenLength : const size_t
            }

            IValidator_T <|.. MessageValidator
            IValidator_T <|.. UserValidator
            IValidator_T <|.. ChatValidator
            IValidator_T <|.. SessionValidator

            
            VariantFactory -[hidden]down-> MessageType_T
            MessageType_T -[hidden]down-> SystemMessageType
            
            SystemMessageType -[hidden]right-> TextMessageType
            TextMessageType -[hidden]right-> DirectChatType
            DirectChatType -[hidden]right-> RegularUserRole
            RegularUserRole -[hidden]right-> UserAction

            MessageValidator -[hidden]right-> UserValidator
            UserValidator -[hidden]right-> ChatValidator
            ChatValidator -[hidden]right-> SessionValidator
    }
}

