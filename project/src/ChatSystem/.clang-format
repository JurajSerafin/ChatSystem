# Based on the Google Cloud C++ client library configuration:
# https://github.com/googleapis/google-cloud-cpp/blob/main/.clang-format
# Original work Copyright 2022 Google LLC, Licensed under Apache 2.0
# Modifications made for ChatSystem project

BasedOnStyle: Google

IndentWidth: 4
ContinuationIndentWidth: 4
AccessModifierOffset: -4
ColumnLimit: 100

# Pointer and reference alignment
DerivePointerAlignment: false
PointerAlignment: Left
ReferenceAlignment: Left

# "const" alignment
QualifierAlignment: Left

# Include sorting
IncludeBlocks: Regroup
SortIncludes: CaseSensitive
IncludeCategories:
  - Regex: '^<[A-Za-z0-9_]*\.h>$'
    Priority: 5
  - Regex: '^<sys/.*\.h>$'
    Priority: 5
  - Regex: '^<boost/'
    Priority: 4
  - Regex: '^<wx/'
    Priority: 4
  - Regex: '^<gtest/'
    Priority: 4
  - Regex: '^<.*>'
    Priority: 3
  - Regex: '^"'
    Priority: 1

# Braces
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Empty
AllowShortBlocksOnASingleLine: false

# Parameters
BinPackParameters: false
AllowAllParametersOfDeclarationOnNextLine: false

# Templates
AlwaysBreakTemplateDeclarations: Yes

# Namespaces
NamespaceIndentation: None
CompactNamespaces: false
FixNamespaceComments: true

# Misc
Cpp11BracedListStyle: true
ReflowComments: true
SortUsingDeclarations: true
Standard: c++20
SpaceBeforeParens: ControlStatements
SpacesInAngles: Never